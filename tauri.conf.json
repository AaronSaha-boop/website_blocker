{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dark Pattern Blocker",
  "version": "0.1.0",
  "identifier": "com.aaron.dark-pattern-blocker",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Dark Pattern Blocker",
        "width": 900,
        "height": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png"
    ],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
